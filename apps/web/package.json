{
    "name": "@occt-draw/web",
    "private": true,
    "version": "0.1.0",
    "dependencies": {
        "@occt-draw/shared": "workspace:*",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "scripts": {
        "build": "pnpm exec tsc -p tsconfig.build.json --pretty false && pnpm exec vite build",
        "clean": "rimraf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
        "dev": "pnpm exec vite",
        "lint": "pnpm exec eslint src --ext .ts,.tsx",
        "typecheck": "pnpm exec tsc -p tsconfig.json --pretty false"
    }
}

{
    "name": "occt-draw-web",
    "private": true,
    "version": "0.1.0",
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=20.11.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "build": "pnpm -r build",
        "check": "pnpm lint && pnpm typecheck && pnpm type-coverage && pnpm format:check && pnpm depcruise && pnpm build",
        "clean": "pnpm -r clean",
        "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
        "depcruise": "depcruise --config dependency-cruiser.cjs \"apps/**/src/**/*.ts\" \"apps/**/src/**/*.tsx\" \"packages/**/src/**/*.ts\" \"packages/**/src/**/*.tsx\"",
        "dev": "pnpm --filter @occt-draw/web dev",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "eslint eslint.config.mjs \"apps/**/src/**/*.ts\" \"apps/**/src/**/*.tsx\" \"packages/**/src/**/*.ts\" \"packages/**/src/**/*.tsx\" --no-error-on-unmatched-pattern",
        "lint:fix": "eslint eslint.config.mjs \"apps/**/src/**/*.ts\" \"apps/**/src/**/*.tsx\" \"packages/**/src/**/*.ts\" \"packages/**/src/**/*.tsx\" --fix --no-error-on-unmatched-pattern",
        "prepare": "husky",
        "typecheck": "pnpm -r typecheck",
        "type-coverage": "type-coverage --project tsconfig.type-coverage.json --at-least 100 --detail --strict"
    },
    "lint-staged": {
        "*.{ts,tsx,mts,cts,mjs,cjs,json,md,yml,yaml}": [
            "prettier --write"
        ],
        "*.{ts,tsx}": [
            "eslint --fix --no-error-on-unmatched-pattern"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@eslint/js": "^9.25.1",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.2",
        "@vitejs/plugin-react": "^5.0.4",
        "dependency-cruiser": "^17.3.10",
        "eslint": "^9.25.1",
        "eslint-config-prettier": "^9.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.4",
        "prettier": "^3.5.3",
        "rimraf": "^6.0.1",
        "type-coverage": "^2.29.7",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.30.1",
        "vite": "^7.1.12"
    }
}
